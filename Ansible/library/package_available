#!/bin/bash

ARGS="(`cat $1`)"
ARGS=$(echo $ARGS | tr -d "^(" | tr -d ")$")

PACKAGE=`echo $ARGS | tr " " "\n"| awk -F= '$1=="PACKAGE"{print $2}'| tr -d '"' | sed -e 's/[[:space:]]*$//'`

yum list $PACKAGE
if [ $? -ne 0 ]; then
AVAILABILITY="false"
else
AVAILABILITY="true"
fi
echo "
{
\"ansible_facts\": {
  \"mypackage_available\": \"${AVAILABILITY}\"
 }
}
"
